# NoteFlow App - Environment Variables
# Copy this file to .env and fill in values.

# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5000

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_abc123xyz
JWT_EXPIRE=7d

# Firebase Admin / Firestore
# Option 1: point to a downloaded Firebase service account JSON file.
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# Option 2: use env vars instead of a JSON file.
# FIREBASE_PROJECT_ID=your-firebase-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-firebase-project-id.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"

# Optional local Firestore emulator:
# FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
